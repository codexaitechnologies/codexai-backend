    {
      "name": "Courses",
      "item": [
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Web Development\",\n  \"duration\": \"12 weeks\",\n  \"iconName\": \"Code\",\n  \"description\": \"Learn full-stack web development with modern technologies\",\n  \"features\": [\n    \"HTML/CSS\",\n    \"JavaScript\",\n    \"React\",\n    \"Node.js\",\n    \"MongoDB\"\n  ],\n  \"projectCount\": \"5\",\n  \"link\": \"/courses/web-dev\",\n  \"colorClass\": {\n    \"from\": \"from-blue-500\",\n    \"to\": \"to-cyan-500\",\n    \"icon\": \"text-blue-600\",\n    \"badge\": \"bg-blue-100\",\n    \"border\": \"border-blue-200\",\n    \"hoverBorder\": \"hover:border-blue-400\",\n    \"hoverShadow\": \"hover:shadow-blue-500/20\"\n  },\n  \"isFlagship\": true,\n  \"image\": \"https://example.com/courses/web-dev.jpg\",\n  \"color\": \"#0066FF\",\n  \"highlights\": [\n    \"Industry-standard technologies\",\n    \"Live project experience\",\n    \"1-on-1 mentoring sessions\",\n    \"Job placement assistance\"\n  ],\n  \"curriculum\": [\n    {\n      \"week\": \"1-2\",\n      \"title\": \"HTML & CSS Fundamentals\",\n      \"topics\": [\n        \"HTML5 structure\",\n        \"CSS layouts\",\n        \"Responsive design\",\n        \"Accessibility basics\"\n      ]\n    },\n    {\n      \"week\": \"3-5\",\n      \"title\": \"JavaScript Essentials\",\n      \"topics\": [\n        \"ES6+ syntax\",\n        \"DOM manipulation\",\n        \"Async programming\",\n        \"API integration\"\n      ]\n    }\n  ],\n  \"outcomes\": [\n    \"Build responsive websites using HTML, CSS, and JavaScript\",\n    \"Master React for building dynamic user interfaces\",\n    \"Develop backend APIs with Node.js and Express\",\n    \"Design and manage databases with MongoDB\",\n    \"Deploy applications to production environments\"\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/courses",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "courses"
              ]
            },
            "description": "Creates a new course with the provided information"
          },
          "response": []
        },
        {
          "name": "Get Course",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/courses/{{courseId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "courses",
                "{{courseId}}"
              ]
            },
            "description": "Retrieves a specific course by its ID"
          },
          "response": []
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"duration\": \"10 weeks\",\n  \"projectCount\": \"6\",\n  \"isFlagship\": false,\n  \"image\": \"https://example.com/courses/web-dev-updated.jpg\",\n  \"color\": \"#FF6600\",\n  \"highlights\": [\n    \"Advanced techniques\",\n    \"Portfolio projects\",\n    \"Internship opportunities\"\n  ],\n  \"curriculum\": [\n    {\n      \"week\": \"1-3\",\n      \"title\": \"HTML & CSS Mastery\",\n      \"topics\": [\n        \"Semantic HTML\",\n        \"CSS Grid\",\n        \"Flexbox\",\n        \"Mobile optimization\"\n      ]\n    }\n  ],\n  \"outcomes\": [\n    \"Deploy full-stack applications\",\n    \"Lead development teams\",\n    \"Contribute to open-source\"\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/courses/{{courseId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "courses",
                "{{courseId}}"
              ]
            },
            "description": "Updates one or more fields of an existing course. All fields are optional."
          },
          "response": []
        },
        {
          "name": "Delete Course",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/courses/{{courseId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "courses",
                "{{courseId}}"
              ]
            },
            "description": "Deletes a course permanently from the database"
          },
          "response": []
        },
        {
          "name": "List Courses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/courses?limit=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "courses"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Number of items to return (default: 10, max: 100)"
                },
                {
                  "key": "flagship",
                  "value": "true",
                  "description": "Filter to only flagship courses (true/false)",
                  "disabled": true
                },
                {
                  "key": "lastEvaluatedKey",
                  "value": "",
                  "description": "Base64-encoded key for pagination",
                  "disabled": true
                }
              ]
            },
            "description": "Retrieves a paginated list of all courses with optional filtering and pagination support"
          },
          "response": []
        }
      ]
