  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phoneNumber\": \"+91-9876543210\",\n  \"course\": \"Web Development\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users"
              ]
            },
            "description": "Creates a new user with the provided information"
          },
          "response": []
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/{{userId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            },
            "description": "Retrieves a specific user by their ID"
          },
          "response": []
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane Doe\",\n  \"course\": \"Data Science\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/{{userId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            },
            "description": "Updates one or more fields of an existing user. All fields are optional."
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/{{userId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            },
            "description": "Deletes a user permanently from the database"
          },
          "response": []
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users?limit=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Number of items to return (default: 10, max: 100)"
                },
                {
                  "key": "lastEvaluatedKey",
                  "value": "",
                  "description": "Base64-encoded key for pagination",
                  "disabled": true
                }
              ]
            },
            "description": "Retrieves a paginated list of all users with optional pagination support"
          },
          "response": []
        }
      ]
    },
    {
