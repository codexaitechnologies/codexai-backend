              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane Doe\",\n  \"course\": \"Data Science\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/{{userId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            },
            "description": "Updates one or more fields of an existing user. All fields are optional."
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/{{userId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            },
            "description": "Deletes a user permanently from the database"
