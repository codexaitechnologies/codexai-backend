              "raw": "{\n  \"title\": \"Web Development\",\n  \"duration\": \"12 weeks\",\n  \"iconName\": \"Code\",\n  \"description\": \"Learn full-stack web development with modern technologies\",\n  \"features\": [\n    \"HTML/CSS\",\n    \"JavaScript\",\n    \"React\",\n    \"Node.js\",\n    \"MongoDB\"\n  ],\n  \"projectCount\": \"5\",\n  \"link\": \"/courses/web-dev\",\n  \"colorClass\": {\n    \"from\": \"from-blue-500\",\n    \"to\": \"to-cyan-500\",\n    \"icon\": \"text-blue-600\",\n    \"badge\": \"bg-blue-100\",\n    \"border\": \"border-blue-200\",\n    \"hoverBorder\": \"hover:border-blue-400\",\n    \"hoverShadow\": \"hover:shadow-blue-500/20\"\n  },\n  \"isFlagship\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/courses",
              "host": [
